      "info": {
        "name": "Events",
        "type": "folder"
      },
      "items": [
        {
          "info": {
            "name": "Send an event",
            "type": "http"
          },
          "http": {
            "method": "POST",
            "url": "https://app.loops.so/api/v1/events/send",
            "headers": [
              {
                "name": "Idempotency-Key",
                "value": ""
              }
            ],
            "body": {
              "type": "json",
              "data": "{}"
