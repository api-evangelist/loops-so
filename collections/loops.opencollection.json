            }
          },
          "docs": "Retrieve a single theme by ID."
        },
        {
          "info": {
            "name": "List themes",
            "type": "http"
          },
          "http": {
            "method": "GET",
            "url": "https://app.loops.so/api/v1/themes",
            "params": [
              {
                "name": "perPage",
                "value": "",
                "type": "query",
                "description": "How many results to return in each request. Must be between 10 and 50. Default is 20."
